import asyncio
import json
import time
import uuid
from typing import Any

from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware

from core.node import Node


node = None
chat_history: list[dict[str, Any]] = []
_event_queue: list[dict[str, Any]] = []

_CHAT_FIELDS = {"id", "from_id", "to", "text", "timestamp", "encrypted"}


def _clean_message(msg: dict) -> dict:
    return {k: v for k, v in msg.items() if k in _CHAT_FIELDS}


def create_app(node_instance: "Node") -> FastAPI:
    global node
    node = node_instance

    app = FastAPI(title="Mesh Network API")

    app.add_middleware(
        CORSMiddleware,
        allow_origins=["*"],
        allow_methods=["*"],
        allow_headers=["*"],
    )

    @app.get("/health")
    async def health() -> dict[str, Any]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            raise HTTPException(status_code=503, detail={"error": "not ready"})
        return {
            "status": "ok",
            "node_id": node.id,
            "peers_count": len(node.get_peers()),
        }

    @app.get("/peers")
    async def get_peers() -> list[dict[str, Any]]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            return []
        return node.get_peers()

    @app.get("/relay")
    async def get_relay() -> dict[str, Any]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            return {"peer_id": "unknown", "name": "unknown"}
        relay = node.get_relay()
        if relay:
            return {"peer_id": relay["peer_id"], "name": relay["name"]}
        return {"peer_id": node.id, "name": node.name}

    @app.get("/messages")
    async def get_messages() -> list[dict[str, Any]]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            return []
        return [_clean_message(m) for m in chat_history]

    @app.post("/send")
    async def send_message(body: dict[str, Any]) -> dict[str, Any]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            raise HTTPException(status_code=503, detail={"error": "not ready"})

        msg = {
            "id": str(uuid.uuid4()),
            "type": "CHAT",
            "from_id": node.id,
            "to": body.get("to", "broadcast"),
            "text": body.get("text", ""),
            "timestamp": time.time(),
            "ttl": 7,
            "encrypted": True,
        }

        chat_history.append(msg)
        if len(chat_history) > 100:
            chat_history.pop(0)

        if node.flood_router:
            await node.flood_router.process(msg, "", is_local=True)
        else:
            await node.broadcast_message(msg)

        return {"message_id": msg["id"]}

    @app.get("/events")
    async def get_events() -> list[dict[str, Any]]:
        if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
            return []
        raw = list(_event_queue)
        _event_queue[:] = []
        result = []
        for event in raw:
            if event.get("type") == "message:received":
                result.append({"type": event["type"], "data": _clean_message(event["data"])})
            else:
                result.append(event)
        return result

    return app


async def push_peer_event(event_type: str, peer: dict[str, Any]):
    if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
        return
    await _push_event({"type": event_type, "data": peer})


async def _push_event(event: dict[str, Any]):
    if node is None:
if not body.get("text", "").strip():            raise HTTPException(status_code=400, detail={"error": "text is required"})
        return
    _event_queue.append(event)
    if len(_event_queue) > 500:
        _event_queue.pop(0)
